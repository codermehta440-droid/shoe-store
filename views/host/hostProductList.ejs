  <%- include('../partials/storePartials/head') %>

<body>

  <%- include('../partials/storePartials/nav') %>

  <main class="host-products-container">

    <div class="top-section">

      <div class="title">
        <h1>Host Products</h1>
        <p>Manage all your products easily</p>
      </div>

      <a href="/host/add-product" class="add-btn">
        Add Product
      </a>

    </div>

    <% if(products.length === 0){ %>

      <div class="empty">

        <h2>No Products Found</h2>

      </div>

    <% } else { %>

      <div class="products-grid">

        <% products.forEach(product => { %>

          <div class="product-card">

            <div class="image">

              <img src="<%= product.image %>" alt="product">

            </div>

            <div class="content">

              <div class="info">

                <h2>
                  <%= product.title %>
                </h2>

                <p class="category">
                  <%= product.category || "No Category" %>
                </p>

                <h3>
                  ₹<%= product.price %>
                </h3>

              </div>

<div class="actions">

  <!-- First Section -->

  <div class="main-actions">

    <a 
      href="/host/editProduct/<%= product._id %>"
      class="edit-btn"
    >
      Edit
    </a>

    <form
      action="/host/delete-product"
      method="POST"
      class="delete-form"
    >

      <input
        type="hidden"
        name="productId"
        value="<%= product._id %>"
      >

      <button
        type="submit"
        class="delete-btn"
      >
        Delete
      </button>

    </form>

  </div>

  <!-- Second Section -->

<div class="extra-actions">

  <form
    action="/host/addPopular"
    method="POST"
  >

    <input
      type="hidden"
      name="productId"
      value="<%= product._id %>"
    >

    <button
      type="submit"
      class="popular-btn"
    >
      Add to Popular
    </button>

  </form>

<form
  action="/host/specialOffer"
  method="POST"
>

  <input
    type="hidden"
    name="productId"
    value="<%= product._id %>"
  >

  <% if(product.isSpecialOffer){ %>

    <button
      type="submit"
      class="remove-offer-btn offer-btn"
    >
      Remove From Special Offer
    </button>

  <% } else { %>

    <button
      type="submit"
      class="offer-btn"
    >
      Special Offer
    </button>

  <% } %>

</form>
</div>

</div>

            </div>

          </div>

        <% }) %>

      </div>

    <% } %>

  </main>

  <script src="/js/hostProductList.js"></script>

</body>
</html>