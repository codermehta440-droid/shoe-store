<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin login</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="/css/mix.css">
    <link rel="stylesheet" href="/css/hostLogin.css">
    
    <!-- linking remix icon -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet"/>
</head>
<body>

  <!-- NAVBAR -->
  <%- include('../partials/authPartials/nav') %>

  <!-- HOST LOGIN SECTION -->
  <main>
    <div class="login-container">

      <!-- LEFT SIDE -->
      <div class="left-side">

        <div class="content">
          <h1>Host Panel Access 🔐</h1>

          <p>
            Login to manage products, orders, dashboard analytics
            and control your footwear store professionally.
          </p>
        </div>

        <!-- DESIGN BOX -->
        <div class="design-box">

          <div class="circle one"></div>
          <div class="circle two"></div>

          <div class="shoe-card">
            <i class="ri-store-2-fill"></i>

            <h3>Admin Dashboard</h3>

            <p>Products • Orders • Analytics</p>
          </div>

        </div>

      </div>

      <!-- RIGHT SIDE -->
      <div class="right-side">

        <div class="form-head">
          <h2>Host Login</h2>
          <p>Enter admin credentials</p>
        </div>

        <!-- ERROR -->
        <% if(error.length > 0){ %>

          <div class="err-msg">

            <% error.forEach(err => { %>

              <ul>
                Error :- <%= err %>
              </ul>

            <% }) %>

          </div>

        <% } %>

        <!-- FORM -->
        <form action="/host/hostLogin" method="POST">

                    <!-- full name -->
          <div class="input-box">

            <label>Full Name</label>

            <div class="input-field">

              <i class="ri-mail-line"></i>

              <input
                type="text"
                placeholder="Enter admin name"
                required
                name="name"
                value="<%= host?.name || 'Shiv Kumar' %>"
                readonly
              />

            </div>

          </div>

          <!-- EMAIL -->
          <div class="input-box">

            <label>Email Address</label>

            <div class="input-field">

              <i class="ri-mail-line"></i>

              <input
                type="email"
                placeholder="Enter admin email"
                required
                name="email"
                value="<%= oldInput?.email || '' %>"
              />

            </div>

          </div>

          <!-- PASSWORD -->
          <div class="input-box">

            <label>Password</label>

            <div class="input-field password-field">

              <i class="ri-lock-line"></i>

              <input
                type="password"
                placeholder="••••••••"
                id="password"
                required
                name="password"
                value="<%= oldInput?.password || '' %>"
              />

              <i class="ri-eye-off-line toggle-password"></i>

            </div>

          </div>

          <!-- REMEMBER -->
          <div class="remember-box">

            <div class="remember">
              <input type="checkbox" />
              <span>Remember Me</span>
            </div>

            <a href="#">Forgot Password?</a>

          </div>

          <!-- BUTTON -->
          <button type="submit" class="login-btn">
            Access Dashboard
          </button>

        </form>

        <!-- OR -->
        <div class="or">
          <span></span>
          <p>SECURE HOST PANEL</p>
          <span></span>
        </div>

        <!-- INFO -->
        <div class="social-login">

          <button>
            <i class="ri-shield-keyhole-fill"></i>
            Protected Access
          </button>

          <button>
            <i class="ri-database-2-fill"></i>
            Host Database
          </button>

        </div>

        <!-- NOTE -->
        <div class="create-account">
          <p>
            Only authorized hosts can access this panel.
          </p>
        </div>

      </div>

    </div>
  </main>

  <!-- JS -->
  <script src="/js/hostLogin.js"></script>

</body>

</html>