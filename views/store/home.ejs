<%- include('../partials/storePartials/head') %>
  <body>
    <!-- ================= NAVBAR ================= -->

    <%- include('../partials/storePartials/nav') %>

    <!-- ================= HERO SECTION ================= -->

    <main>
      <div class="ui">
        <div class="text">
          <h1>
            Make A Good <br />
            Journey With <span>Shoe</span>
          </h1>

          <p>
            Shoes are essential footwear designed to protect and comfort human
            feet while also serving as major fashion and lifestyle items.
          </p>

          <div class="btn">
            <button><a href="#">Explore Now</a></button>
            <button><a href="#">More Info.</a></button>
          </div>
        </div>

        <div class="img">
          <img src="/images/UI next.png" alt="hero image" />
        </div>
        </div>

        <!-- ================= POPULAR PRODUCTS ================= -->

        <div class="t-category">
          <div class="head">
            <h2>Our <span>Popular</span> Products</h2>

            <p>Discover our most popular footwear collections.</p>
          </div>

          <div class="arrow">
            <div class="left"><i class="ri-arrow-left-circle-fill"></i></div>

            <div class="frame">
              <div class="products">
                <% if (popularProducts && popularProducts.length > 0) { %>
                  <% popularProducts.forEach((item) => { %>
                    <div class="product-cards">
                      <a href="/details/<%= item._id %>" class="detailsLinks">
                        <div class="img">
                          <img src="<%= item.image %>" alt="<%= item.title %>" />
                          <div class="add-fav"><i class="ri-heart-line"></i></div>
                        </div>
                      </a>

                      <div class="text">
                        <div class="color">
                          <div class="colors">
                            <div class="col1"></div>
                            <div class="col2"></div>
                            <div class="col3"></div>
                            <div class="col4"></div>
                          </div>
                          <div class="rate">
                            <i class="ri-star-s-fill"></i>
                            <i class="ri-star-s-fill"></i>
                            <i class="ri-star-s-fill"></i>
                            <i class="ri-star-half-s-line"></i>
                          </div>
                        </div>
                        <name>
                          <h3 id="name"><%= item.title %></h3>
                          <h4 id="price">₹<%= item.price %></h4>
                        </name>
                        <p><%= item.description ? item.description.slice(0, 60) : '' %>...</p>
                      </div>

                      <div class="btn">
                        <form action="/cart/add/<%= item._id %>" method="POST">
                          <button type="submit">Add to cart</button>
                        </form>
                      </div>
                    </div>
                  <% }) %>
                <% } else { %>
                  <div class="product-cards">
                    <div class="text">
                      <h3>No popular products found</h3>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>

            <div class="right"><i class="ri-arrow-right-circle-fill"></i></div>
          </div>
        </div>

        <!-- ================= SHOE DETAILS -->

      <div class="shoe-details">
        <div class="img">
          <img src="/images/product-detail.png" alt="" />
        </div>

        <div class="text">
          <div class="qualities">
            <h3>Pure Leather</h3>

            <p>
              Pure leather shoes offer superior durability, breathability, and
              comfort.
            </p>
          </div>

          <div class="qualities">
            <h3>Water Resistance Sneakers</h3>

            <p>
              Water-resistant shoes protect against moisture and light rain.
            </p>
          </div>

          <div class="qualities">
            <h3>Comfortable</h3>

            <p>Designed for all-day standing and walking.</p>
          </div>
        </div>
      </div>

      <!-- the offers section -->
      <div class="special-offers">
        <div class="head">
          <h2>Our <span>Special</span> Offers</h2>
          <p>
            Discover our most popular and curated footwear collections. Based on
            2026 e-commerce trends, here are top category products organized
            into.
          </p>
        </div>

<div class="products">

  <% if(specialProducts.length === 0){ %>

    <h2>No Special Offer Products</h2>

  <% } else { %>

    <% specialProducts.forEach(product => { %>

      <div class="product-cards">

        <a href="/details/<%= product._id %>">

          <div class="img">

            <img src="<%= product.image %>" alt="" />

            <div class="rate">

              <h4>4.5</h4>

              <i class="ri-star-s-fill"></i>

              <h4 id="rateCount">(1,000)</h4>

            </div>

          </div>

        </a>

<div class="text">

  <name>

    <h3 id="name">
      <%= product.title %>
    </h3>

    <h4 id="price">

      <span class="old-price">
        ₹<%= product.price + 400 %>
      </span>

      ₹<%= product.price %>

    </h4>

  </name>

  <p class="desc">
    <%= product.description %>
  </p>

</div>

      </div>

    <% }) %>

  <% } %>

</div>
      </div>

      <!-- ================= ADVERTISE SECTION ================= -->

      <div class="advertise">
        <div class="arrows">
          <div class="left">
            <i class="ri-arrow-left-circle-fill"></i>
          </div>

          <div class="right">
            <i class="ri-arrow-right-circle-fill"></i>
          </div>
        </div>

        <div class="frame">
          <!-- slide 1 -->

          <div class="sliders active">
            <div class="text">
              <h1>The Best Shoe Of This Session</h1>

              <p>
                Experience unmatched comfort and premium design with the latest
                sneaker collection.
              </p>

              <a href="#">Shop Now</a>
            </div>

            <div class="img">
              <img src="/images/best shoe (year).png" alt="" />
            </div>
          </div>

          <!-- slide 2 -->

          <div class="sliders">
            <div class="text">
              <h1>Modern Sneakers Collection</h1>

              <p>Discover lightweight running shoes with modern aesthetics.</p>

              <a href="#">Explore</a>
            </div>

            <div class="img">
              <img src="/images/modern sneakers(ads).png" alt="" />
            </div>
          </div>

          <!-- Slide 3 -->
          <div class="sliders">
            <div class="text">
              <h1>
                Premium Sports <br />
                Footwear
              </h1>
              <p>
                Designed for athletes and trendsetters with premium cushioning,
                durable sole, and futuristic styling.
              </p>
              <a href="/shop">Buy Now</a>
            </div>

            <div class="img">
              <img src="/images/premium sport(ads).png" alt="" />
            </div>
          </div>

          <!-- Slide 4 -->
          <div class="sliders">
            <div class="text">
              <h1>
                Classic Street <br />
                Fashion Shoes
              </h1>
              <p>
                Upgrade your streetwear game with bold colors, stylish design,
                and maximum comfort for every step.
              </p>
              <a href="/shop">See More</a>
            </div>

            <div class="img">
              <img src="/images/shoe2(ads).png" alt="" />
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- ================= FOOTER ================= -->

    <footer>
      <div class="footer-container">
        <!-- about -->
        <div class="footer-box">
          <div class="logo">
            <img src="/images/logo.png" alt="" />
          </div>

          <p>
            Discover premium quality footwear designed for comfort, fashion, and
            performance.
          </p>

          <div class="social">
            <a href="#">
              <i class="ri-facebook-fill"></i>
            </a>

            <a href="#">
              <i class="ri-instagram-line"></i>
            </a>

            <a href="#">
              <i class="ri-twitter-x-line"></i>
            </a>

            <a href="#">
              <i class="ri-youtube-fill"></i>
            </a>
          </div>
        </div>

        <!-- links -->
        <div class="footer-box">
          <h3>Quick Links</h3>

          <a href="#">Home</a>
          <a href="#">About</a>
          <a href="#">Products</a>
          <a href="#">Shoes</a>
        </div>

        <!-- categories -->
        <div class="footer-box">
          <h3>Categories</h3>

          <a href="#">Sneakers</a>
          <a href="#">Sports Shoes</a>
          <a href="#">Formal Shoes</a>
          <a href="#">Sandals</a>
        </div>

        <!-- contact -->
        <div class="footer-box">
          <h3>Contact Info</h3>

          <p>
            <i class="ri-map-pin-line"></i>
            Bihar, India
          </p>

          <p>
            <i class="ri-phone-line"></i>
            +91 98765 43210
          </p>

          <p>
            <i class="ri-mail-line"></i>
            footwear@gmail.com
          </p>
        </div>
      </div>

      <!-- bottom -->
      <div class="footer-bottom">
        <p>© 2026 Footwear Website | Designed By Developer Dev</p>
      </div>
    </footer>

    <!-- JS -->
    <script src="/js/home.js"></script>
  </body>
</html>
