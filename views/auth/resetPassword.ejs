<%- include('../partials/authPartials/head') %>

<body>

<%- include('../partials/authPartials/nav') %>

<div class="login-container">

    <div class="right-side">

        <div class="form-head">

            <h2>Set New Password</h2>

        </div>

        <% if(error.length > 0){ %>

            <div class="err-msg">

                <% error.forEach(err => { %>

                    <ul><%= err %></ul>

                <% }) %>

            </div>

        <% } %>

        <form action="/reset-password" method="POST">

            <input
                type="hidden"
                name="token"
                value="<%= token %>"
            >

            <div class="input-box">

                <label>New Password</label>

                <div class="input-field">

                    <input
                        type="password"
                        name="password"
                        required
                    >

                </div>

            </div>

            <div class="input-box">

                <label>Confirm Password</label>

                <div class="input-field">

                    <input
                        type="password"
                        name="confirmPassword"
                        required
                    >

                </div>

            </div>

            <button
                class="login-btn"
                type="submit">

                Update Password

            </button>

        </form>

    </div>

</div>

</body>